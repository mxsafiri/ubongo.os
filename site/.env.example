# Ubongo Landing Page — Vercel Environment Variables
#
# Required for the /api/request-invite serverless function (auto-emails
# signed invite codes via Gmail SMTP). Set these in the Vercel dashboard
# under Project Settings → Environment Variables (or via `vercel env add`).

# Gmail account that sends the invite emails.
GMAIL_USER=v.muhagachi@gmail.com

# 16-char Google App Password (NOT your regular Gmail password).
# Generate at https://myaccount.google.com/apppasswords (requires 2FA).
GMAIL_APP_PASSWORD=

# Shared HMAC secret — must match INVITE_SECRET on the Fly proxy.
# The API function signs codes with this; the proxy validates them.
INVITE_SECRET=

# Display name in the From: header. Defaults to "Ubongo".
INVITE_FROM_NAME=Ubongo
